# Copy to .env and fill in real values. The .env file is gitignored.
# Django
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True

# PostgreSQL
DB_ENGINE=django.db.backends.postgresql
DB_NAME=notser
DB_USER=notser_user
DB_PASSWORD=your-db-password
DB_HOST=localhost
DB_PORT=5432

# Email. Defaults to the console backend (prints emails to the terminal).
# To send real mail, uncomment and fill these in:
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.example.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=your-smtp-user
# EMAIL_HOST_PASSWORD=your-smtp-password
# EMAIL_USE_TLS=True
# DEFAULT_FROM_EMAIL=notifications@yourdomain.com

# Twilio (SMS). Leave blank to keep the SMS sender as a stub. Set all three to
# send real SMS (trial accounts: only to verified numbers).
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=your-auth-token
# TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# FCM (Push). Absolute path to your Firebase service-account JSON.
# FCM_CREDENTIALS_FILE=/absolute/path/to/firebase-service-account.json
